# GitHub App / PAT
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Database (asyncpg for API, psycopg2 URL auto-derived for workers)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/code_review

# Redis
REDIS_URL=redis://redis:6379/0

# App
LOG_LEVEL=INFO
PROMPTS_DIR=./prompts
